{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://abdeep/schemas/calibration-manifest/1.0.0",
  "title": "CalibrationManifest",
  "type": "OBJECT",
  "required": ["exportedAt", "schemaVersion", "runId", "files", "environment"],
  "properties": {
    "exportedAt": {
      "type": "STRING",
      "format": "date-time"
    },
    "schemaVersion": {
      "type": "INTEGER",
      "minimum": 1,
      "maximum": 1
    },
    "schema_version": {
      "type": "STRING",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "runId": {
      "type": "STRING",
      "minLength": 1
    },
    "files": {
      "type": "ARRAY",
      "items": {
        "type": "STRING"
      }
    },
    "environment": {
      "type": "STRING",
      "enum": ["CI", "local"]
    }
  }
}
